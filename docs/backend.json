
{
  "entities": {
    "VaultFile": {
      "title": "VaultFile",
      "description": "Represents an encrypted asset stored in the vault.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "size": { "type": "string" },
        "encryptedData": { "type": "string", "description": "AES-256 encrypted payload" },
        "isHoneyfile": { "type": "boolean", "description": "If true, access triggers immediate high risk" },
        "sensitivityLevel": { "type": "string", "enum": ["Low", "Moderate", "High", "Critical"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "encryptedData", "isHoneyfile", "sensitivityLevel"]
    },
    "SecurityLog": {
      "title": "SecurityLog",
      "description": "Audit trail for system events with risk scoring.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "ipAddress": { "type": "string" },
        "deviceInfo": { "type": "string" },
        "riskScore": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "reasons": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "action", "timestamp", "riskScore", "riskLevel"]
    },
    "User": {
      "title": "User",
      "description": "User profile with adaptive security state.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isLocked": { "type": "boolean" },
        "currentRiskLevel": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "lastLoginAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "isLocked", "currentRiskLevel"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and security state."
    },
    "/vaultFiles/{fileId}": {
      "schema": { "$ref": "#/backend/entities/VaultFile" },
      "description": "Encrypted file metadata and storage references."
    },
    "/securityLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/SecurityLog" },
      "description": "Global audit logs for threat detection."
    }
  }
}
